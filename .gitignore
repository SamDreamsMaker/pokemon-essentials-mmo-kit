# Audio, Graphics and Plugins folders
Audio/
Graphics/
Plugins/*
# ...but keep the versioned MMO SDK plugin (throwaway/diagnostic plugins stay ignored)
!Plugins/PokeMMO/
Screenshots/

# Data folder, but not Data/Scripts folder or messages_core.dat
Data/*
!Data/Scripts.rxdata
!Data/Scripts/
!Data/messages_core.dat

# Files in the main project folder
errorlog.txt
Game.ini
Game.rxproj
RGSS*.dll

# PokeMMO SDK runtime artifacts (logs + throwaway diagnostic reports)
mmo.log
mmo_*.txt
mmo_*.json
# per-machine connection config (each deployment sets its own; documented in README)
mmo_config.txt
# Phase 2: per-machine account id + the host's authoritative account state store
mmo_account.dat
server_saves/
# Base-kit shortcut duplicated by the merged Essentials install
Essentials Docs Wiki.URL

# Common code editor folders & files
.vscode/
*.code-workspace
.idea/
*.mkproj

# Operating system generated files & folders
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db
[Dd]esktop.ini

# Temp files

~*
